# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://maengelmelder:password@localhost:5432/maengelmelder_dev"
POSTGRES_USER=maengelmelder
POSTGRES_PASSWORD=password
POSTGRES_DB=maengelmelder_dev

# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REPORT=3

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@musterhausen.de
SMTP_PASS=your-smtp-password
EMAIL_FROM="Mängelmelder Musterhausen <noreply@musterhausen.de>"

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api/v1

# ─── Stadt-Konfiguration (initial, danach über Admin-UI) ─────────────────────
CITY_NAME="Stadt Musterhausen"
CITY_DEFAULT_LAT=48.1374
CITY_DEFAULT_LNG=11.5755
CITY_DEFAULT_ZOOM=13
